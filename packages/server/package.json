{
  "name": "@radio-services/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx/esm src/server.ts",
    "dev:watch": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@radio-services/core": "file:../core",
    "@radio-services/shared": "file:../shared",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^10.0.0",
    "fastify": "^4.28.0",
    "pino": "^9.4.0",
    "pino-roll": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
